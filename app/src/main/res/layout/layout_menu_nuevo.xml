<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="220dp"
    android:layout_height="wrap_content"
    android:background="#2B2B2B"
    android:elevation="8dp"
    android:scrollbars="vertical"
    android:fadeScrollbars="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingVertical="4dp">

        <TextView
            android:id="@+id/itemNuevoKotlin"
            style="@style/MenuContextualItem"
            android:text="Archivo/Clase Kotlin" />

        <TextView
            android:id="@+id/itemNuevoJava"
            style="@style/MenuContextualItem"
            android:text="Archivo/Clase Java" />

        <TextView
            android:id="@+id/itemNuevoLayout"
            style="@style/MenuContextualItem"
            android:text="Archivo Layout XML" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="4dp"
            android:background="#3D3D3D" />

        <TextView
            android:id="@+id/itemNuevoDirectorio"
            style="@style/MenuContextualItem"
            android:text="Directorio" />

        <TextView
            android:id="@+id/itemNuevoArchivo"
            style="@style/MenuContextualItem"
            android:text="Archivo" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="4dp"
            android:background="#3D3D3D" />

        <TextView
            android:id="@+id/itemNuevoActivity"
            style="@style/MenuContextualItem"
            android:text="Activity" />

        <TextView
            android:id="@+id/itemNuevoFragment"
            style="@style/MenuContextualItem"
            android:text="Fragment" />

    </LinearLayout>
</ScrollView>